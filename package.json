{
  "name": "malazan-atlas-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tiles:source": "node scripts/generate-map-tiles.mjs",
    "assets:validate": "node scripts/validate-atlas-assets.mjs",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "tiles:relief": "node scripts/generate-relief-tiles.mjs",
    "tiles:all": "npm run tiles:source && npm run tiles:relief",
    "tiles:premium": "node scripts/generate-premium-relief-tiles.mjs",
    "cartography:v2:preview": "node scripts/generate-cartography-v2-preview.mjs",
    "tiles:v2": "node scripts/generate-stylized-v2-tiles.mjs",
    "extract:water": "python3 scripts/extract-water-features.py",
    "extract:terrain": "python3 scripts/extract-terrain-features.py"
  },
  "dependencies": {
    "@react-three/drei": "latest",
    "@react-three/fiber": "latest",
    "@react-three/postprocessing": "latest",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "ol": "^10.9.0",
    "postprocessing": "latest",
    "rbush": "^4.0.1",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "^4.4.3",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "vitest": "^4.1.10"
  }
}
